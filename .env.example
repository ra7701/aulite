# Upstream AI provider API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI (optional)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4
# AZURE_OPENAI_API_VERSION=2024-02-01

# Aulite server config (optional, defaults shown)
# AULITE_PORT=3000
# AULITE_HOST=0.0.0.0

# Compliance domains (comma-separated)
# Available: hr, finance, biometrics, education, infrastructure,
#            law-enforcement, migration, justice
# AULITE_DOMAINS=hr,finance

# API key auth (comma-separated, recommended for production)
# AULITE_API_KEYS=your-secret-key

# Rate limiting (requests per minute)
# AULITE_RATE_LIMIT=60

# Custom rules directory (optional)
# AULITE_RULES_DIR=./my-rules
